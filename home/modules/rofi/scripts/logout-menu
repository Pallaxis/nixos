#!/usr/bin/env bash
# Simple app launcher that shows a list of options and handles them by on a case basis

options=$(
    echo "пЂЈ Lock"
    echo "у°¤„ Sleep"
    echo "вЏ» Power Off"
    echo "пѓў Reboot"
    echo "у°—Ѕ Logout"
)

selection=$(pkill fuzzel || echo -e "$options" | fuzzel --dmenu -i -p "Logout Menu")
if [[ -z $selection ]]; then
    exit
fi

case "$selection" in
    "пЂЈ Lock")
        sleep 0.5
        loginctl lock-session
        ;;
    "у°¤„ Sleep")
        systemctl suspend
        ;;
    "вЏ» Power Off")
        systemctl poweroff
        ;;
    "пѓў Reboot")
        systemctl reboot
        ;;
    "у°—Ѕ Logout")
        loginctl terminate-user ''
        ;;
    *)
        echo "how did we get here"
        ;;
esac
